.elementor-button,
.elementor-button:visited,
.elementor-button-link {
  background-color: #ff7a00 !important;
  color: #000000 !important;
  border: none !important;
  border-radius: 30px !important;
}
#botao-conversao-pc,
#botao-conversao-mobile {
  background: #ff7a00 !important;
  color: #000000 !important;
  border-radius: 30px !important;
  border: none !important;
}

#botao-conversao-pc .elementor-button-text,
#botao-conversao-mobile .elementor-button-text {
  color: #000000 !important;
}

/* ===== FORMULÁRIO LARANJA ===== */

.elementor-form .elementor-field {
  border: 2px solid #ff7b008c !important;
  background-color: transparent !important;
  color: #000000 !important;
}

/* Placeholder */
.elementor-form .elementor-field::placeholder {
  color: #000000 !important;
}

/* Quando clicar */
.elementor-form .elementor-field:focus {
  border-color: #ff7a00 !important;
  box-shadow: 0 0 8px rgba(255, 122, 0, 0.6) !important;
  outline: none !important;
}

/* Checkbox */
.elementor-form input[type="checkbox"] {
  accent-color: #ff7a00 !important;
}

/* Botão */
.elementor-form button {
  background: #ff7b00 !important;
  border: none !important;
  color: rgb(0, 0, 0) !important;
}

/* Hover botão */
.elementor-form button:hover {
  background: #ff950071 !important;
}
.social-icon {
  width: 40px;
  height: 40px;
  filter: brightness(0) saturate(100%) invert(48%) sepia(95%) saturate(1200%)
    hue-rotate(2deg) brightness(102%) contrast(101%);
  transition: filter 0.3s ease;
}

.social-icon:hover {
  filter: brightness(0) saturate(100%) invert(100%) sepia(0%) saturate(0%)
    brightness(100%) contrast(100%);
}
